import { motion, useInView } from "framer-motion";
import { useEffect, useMemo, useRef, useState, type FormEvent } from "react";

type Inquiry = {
  name: string;
  email: string;
  date: string;
  venue: string;
  vibe: string;
  notes: string;
};

const storageKey = "djnish-inquiry";

const emptyInquiry: Inquiry = {
  name: "",
  email: "",
  date: "",
  venue: "",
  vibe: "",
  notes: "",
};

export default function Booking() {
  const ref = useRef<HTMLDivElement>(null);
  const isInView = useInView(ref, { once: true, amount: 0.25 });
  const [form, setForm] = useState<Inquiry>(emptyInquiry);
  const [submitted, setSubmitted] = useState<Inquiry | null>(null);
  const [savedAt, setSavedAt] = useState<string | null>(null);

  useEffect(() => {
    const raw = window.localStorage.getItem(storageKey);
    if (!raw) return;

    const parsed = JSON.parse(raw) as { inquiry?: Inquiry; savedAt?: string };
    if (parsed.inquiry) setSubmitted(parsed.inquiry);
    if (parsed.savedAt) setSavedAt(parsed.savedAt);
  }, []);

  const preview = useMemo(() => submitted ?? form, [submitted, form]);

  const update = (key: keyof Inquiry, value: string) => {
    setSubmitted(null);
    setForm((current) => ({ ...current, [key]: value }));
  };

  const handleSubmit = (event: FormEvent<HTMLFormElement>) => {
    event.preventDefault();
    const payload = {
      inquiry: form,
      savedAt: new Date().toISOString(),
    };

    window.localStorage.setItem(storageKey, JSON.stringify(payload));
    setSubmitted(form);
    setSavedAt(payload.savedAt);
  };

  return (
    <section ref={ref} id="booking" className="relative overflow-hidden px-6 py-24 sm:py-32">
      <div className="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[0.95fr_1.05fr]">
        <motion.div
          initial={{ opacity: 0, y: 20 }}
          animate={isInView ? { opacity: 1, y: 0 } : {}}
          transition={{ duration: 0.6 }}
        >
          <span className="section-kicker">Inquiry</span>
          <h2 className="display-heading mt-4 text-4xl font-bold sm:text-5xl lg:text-6xl">
            Send the request.
          </h2>
          <p className="section-copy mt-5 text-base sm:text-lg leading-relaxed">
            Share your event details below. I'll save your submission and keep it visible on the page for your reference.
          </p>

          <div className="mt-8 grid gap-3">
            {[
              "Date, venue, and city",
              "Crowd size and vibe",
              "Your sound preferences",
            ].map((item) => (
              <div key={item} className="bg-surface/40 border border-stroke/40 flex items-start gap-3 p-4 rounded-lg">
                <span className="mt-1 h-2 w-2 rounded-full bg-brand-pink flex-shrink-0" />
                <p className="text-sm leading-relaxed text-text">{item}</p>
              </div>
            ))}
          </div>
        </motion.div>

        <motion.div
          className="bg-surface/50 border border-stroke/40 p-6 sm:p-8 rounded-xl"
          initial={{ opacity: 0, y: 20 }}
          animate={isInView ? { opacity: 1, y: 0 } : {}}
          transition={{ duration: 0.6, delay: 0.08 }}
        >
          <form className="grid gap-4" onSubmit={handleSubmit}>
            <input
              type="text"
              value={form.name}
              onChange={(e) => update("name", e.target.value)}
              placeholder="Your name"
              className="w-full rounded-lg border border-stroke/40 bg-bg/60 px-4 py-3 text-sm text-text placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-brand-pink/40 transition-all"
            />
            <input
              type="email"
              value={form.email}
              onChange={(e) => update("email", e.target.value)}
              placeholder="Email address"
              className="w-full rounded-lg border border-stroke/40 bg-bg/60 px-4 py-3 text-sm text-text placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-brand-pink/40 transition-all"
            />
            <input
              type="date"
              value={form.date}
              onChange={(e) => update("date", e.target.value)}
              className="w-full rounded-lg border border-stroke/40 bg-bg/60 px-4 py-3 text-sm text-text focus:outline-none focus:ring-2 focus:ring-brand-pink/40 transition-all"
            />
            <input
              type="text"
              value={form.venue}
              onChange={(e) => update("venue", e.target.value)}
              placeholder="Venue or city"
              className="w-full rounded-lg border border-stroke/40 bg-bg/60 px-4 py-3 text-sm text-text placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-brand-pink/40 transition-all"
            />
            <input
              type="text"
              value={form.vibe}
              onChange={(e) => update("vibe", e.target.value)}
              placeholder="Sound direction (house, techno, etc.)"
              className="w-full rounded-lg border border-stroke/40 bg-bg/60 px-4 py-3 text-sm text-text placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-brand-pink/40 transition-all"
            />
            <textarea
              value={form.notes}
              onChange={(e) => update("notes", e.target.value)}
              placeholder="Additional details..."
              className="min-h-32 w-full rounded-lg border border-stroke/40 bg-bg/60 px-4 py-3 text-sm text-text placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-brand-pink/40 transition-all resize-none"
            />

            <div className="mt-2 flex flex-col gap-3 sm:flex-row">
              <button type="submit" className="accent-button px-6 py-3 text-xs font-semibold uppercase tracking-[0.2em]">
                Submit
              </button>
              <button
                type="button"
                onClick={() => {
                  setForm(emptyInquiry);
                  setSubmitted(null);
                  setSavedAt(null);
                  window.localStorage.removeItem(storageKey);
                }}
                className="ghost-button px-6 py-3 text-xs font-semibold uppercase tracking-[0.2em]"
              >
                Clear
              </button>
            </div>
          </form>

          <div className="mt-6 bg-surface/60 border border-stroke/40 p-4 rounded-lg">
            <p className="text-xs uppercase tracking-[0.2em] text-muted font-medium">Preview</p>
            <div className="mt-4 grid gap-2.5 text-sm text-text">
              <p><span className="text-muted text-xs uppercase tracking-[0.12em] font-medium">Name:</span> {preview.name || "—"}</p>
              <p><span className="text-muted text-xs uppercase tracking-[0.12em] font-medium">Email:</span> {preview.email || "—"}</p>
              <p><span className="text-muted text-xs uppercase tracking-[0.12em] font-medium">Date:</span> {preview.date || "—"}</p>
              <p><span className="text-muted text-xs uppercase tracking-[0.12em] font-medium">Venue:</span> {preview.venue || "—"}</p>
              <p><span className="text-muted text-xs uppercase tracking-[0.12em] font-medium">Sound:</span> {preview.vibe || "—"}</p>
              <p><span className="text-muted text-xs uppercase tracking-[0.12em] font-medium">Notes:</span> {preview.notes || "—"}</p>
              {savedAt ? <p className="pt-2 text-xs uppercase tracking-[0.16em] text-muted">Saved {new Date(savedAt).toLocaleString()}</p> : null}
            </div>
          </div>
        </motion.div>
      </div>
    </section>
  );
}
